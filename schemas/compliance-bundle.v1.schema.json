{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stateset.com/schemas/compliance-bundle.v1.json",
  "title": "StateSet Compliance Bundle v1",
  "description": "A bundle of independent STARK policy attestations for a single commerce transaction. Each proof is portable per-policy: a regulator can verify AML threshold without seeing the amount, an exchange can verify agent authorization without seeing the cap, etc. The bundle is bound to the underlying transaction via deliveryReceiptHash anchored on chain.",
  "type": "object",
  "required": ["schema", "issuedAt", "transaction", "bundleHash", "proofs", "publicProperties"],
  "additionalProperties": false,
  "properties": {
    "schema":   { "const": "stateset.compliance-bundle.v1" },
    "issuedAt": { "type": "string", "format": "date-time" },
    "transaction": {
      "type": "object",
      "required": ["orderId", "buyer", "seller", "amountUnits", "intentHash", "lockTx", "releaseTx", "deliveryReceiptHash"],
      "additionalProperties": false,
      "properties": {
        "orderId":             { "$ref": "#/$defs/bytes32Hex" },
        "orderText":           { "type": "string" },
        "buyer":               { "$ref": "#/$defs/ethAddress" },
        "seller":              { "$ref": "#/$defs/ethAddress" },
        "amountUsd":           { "type": "number", "exclusiveMinimum": 0 },
        "amountUnits":         { "$ref": "#/$defs/uintString" },
        "intentHash":          { "$ref": "#/$defs/bytes32Hex" },
        "lockTx":              { "$ref": "#/$defs/txHash" },
        "releaseTx":           { "$ref": "#/$defs/txHash" },
        "deliveryReceiptHash": { "$ref": "#/$defs/bytes32Hex" }
      }
    },
    "bundleHash": { "$ref": "#/$defs/bytes32Hex" },
    "proofs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["policy", "publicInputs", "proofHash", "bundleHash", "metadata", "limit"],
        "additionalProperties": true,
        "properties": {
          "policy":        { "enum": ["order_total.cap", "aml.threshold", "agent.authorization.v1"] },
          "publicInputs":  { "type": "object" },
          "proofHash":     { "$ref": "#/$defs/bytes32Hex" },
          "bundleHash":    { "$ref": "#/$defs/bytes32Hex" },
          "metadata": {
            "type": "object",
            "required": ["proving_time_ms", "proof_size", "prover_version"],
            "properties": {
              "proving_time_ms": { "type": "integer", "minimum": 0 },
              "proof_size":      { "type": "integer", "minimum": 1 },
              "prover_version":  { "type": "string" }
            }
          },
          "limit":         { "type": "integer", "minimum": 1 },
          "intentHash":    { "anyOf": [{ "$ref": "#/$defs/bytes32Hex" }, { "type": "null" }] },
          "proofFilePath": {
            "type": "string",
            "description": "Filesystem path to the canonical proof JSON the verifier reads. The bundle is portable when both the receipt and the proofs/ directory travel together."
          }
        }
      }
    },
    "publicProperties": {
      "type": "object",
      "description": "Human-readable summary of what each policy publicly attests, for non-technical auditors.",
      "additionalProperties": { "type": "string" }
    }
  },
  "$defs": {
    "ethAddress": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
    "bytes32Hex": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
    "txHash":     { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
    "uintString": { "type": "string", "pattern": "^[0-9]+$" }
  }
}
